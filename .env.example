# Copy to .env and fill in. .env is gitignored and never committed.
# In CI, set these as repository secrets instead of using a file.

# vaults.fyi V2 API key (primary source for yield + covered balances)
VAULTSFYI_API_KEY=

# Dune Analytics API key (wallet registry, reconciliation, moved-funds KPI)
DUNE_API_KEY=

# Slack incoming webhook URL for validation-gate alerts (optional but recommended)
SLACK_WEBHOOK_URL=
